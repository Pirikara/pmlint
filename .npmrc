# pmlint dogfoods the package-manager policy it lints for.
# Keep installs deterministic and hardened.

# Save new dependencies as exact versions (no leading ^ / ~).
save-exact=true

# Refuse to run under a pnpm version other than the one pinned in
# package.json#packageManager, and don't auto-switch silently.
package-manager-strict=true
manage-package-manager-versions=true

# Fail the install if the lockfile is missing or out of date instead of
# silently mutating it. (Equivalent to --frozen-lockfile when CI=true.)
# Local installs stay flexible; CI is expected to set CI=true.
